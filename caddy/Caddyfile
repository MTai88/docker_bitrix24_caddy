# =============================================================
# Caddyfile для Bitrix24
# =============================================================
# Поведение:
#   - Для локальной разработки (LOCAL_DEV=true): сайт работает ТОЛЬКО
#     по HTTP на порту 80. Подключайтесь через http://bitrix.local
#     (добавьте в /etc/hosts: 127.0.0.1 bitrix.local) или http://localhost.
#   - Для продакшна (LOCAL_DEV=false): измените Caddyfile, чтобы включить
#     HTTPS (см. README раздел "Продакшн-окей").
#
# Структура файла:
#   - глобальная секция (admin off)
#   - сайтовый блок {$DOMAIN}, localhost, 127.0.0.1, ::1
#   - маршруты: PHP, статика, push-сервер, mailhog, healthcheck
# =============================================================

{
    admin off
    # Отключаем auto_https: иначе Caddy по умолчанию редиректит HTTP→HTTPS
    # (308), а PHP-контейнер внутри docker-сети не доверяет самоподписанному
    # сертификату Caddy (tls internal) и не может опубликовать push-события.
    # Публичный HTTPS остаётся доступным через явный https://-блок ниже.
    # Отключаем только автоматический HTTP→HTTPS-редирект (disable_redirects),
    # но НЕ auto_https целиком: иначе Caddy перестанет выпускать TLS-сертификат
    # для https://-блока и HTTPS рукопожатие будет падать.
    # Нужно это потому, что PHP-контейнер внутри docker-сети не доверяет
    # самоподписанному сертификату Caddy (tls internal) и не может опубликовать
    # push-события, если получит 308 на HTTPS при попытке POST по HTTP.
    auto_https disable_redirects
}

# Главный сайт — {$DOMAIN} (плюс localhost для удобства разработки).
# Блок разделён на два: HTTP-only (межсервисный push + редирект всего
# остального на HTTPS) и HTTPS (публичный сайт).
# auto_https off в глобальной секции нужен, чтобы HTTP-запросы не
# редиректились автоматически — иначе PHP-контейнер внутри docker-сети
# не сможет опубликовать push-события (не доверяет tls internal).

# ---------- HTTP-only listener ----------
# /bitrix/pub/, /bitrix/pubweb/, /bitrix/api/ — POST от Битрикса → push-server PUB.
# /bitrix/sub/, /bitrix/subws/ — клиентская подписка → push-server SUB.
# Остальное — редирект на HTTPS-зеркало того же хоста.
http://{$DOMAIN}, http://localhost, http://127.0.0.1, http://[::1], http://caddy {
    # Публикация команд со стороны Битрикса (PHP) и JSON-RPC.
    # route с inline matchers — более высокий приоритет, чем redir.
    route {
        @pushPub path /bitrix/pub /bitrix/pub/ /bitrix/pub/* /bitrix/pubweb /bitrix/pubweb/ /bitrix/pubweb/* /bitrix/api /bitrix/api/ /bitrix/api/*
        handle @pushPub {
            reverse_proxy push-server:8010 {
                transport http {
                    dial_timeout 30s
                    response_header_timeout 60s
                    read_timeout 3600s
                    write_timeout 60s
                }
            }
        }
    }

    # Подписка клиентов на события push.
    route {
        @pushSub path /bitrix/sub* /bitrix/subws*
        handle @pushSub {
            reverse_proxy push-server-sub:8011 {
                transport http {
                    dial_timeout 30s
                    response_header_timeout 60s
                    read_timeout 3600s
                    write_timeout 60s
                }
            }
        }
    }

    # Всё прочее по HTTP (включая запросы извне) — на HTTPS-зеркало.
    # ВАЖНО: redir должен идти ПОСЛЕ всех handle и быть в отдельном handle
    # для unmatched paths, иначе он перехватывает ВСЕ запросы, включая
    # те, что матчатся нашими pushPub/pushSub matcher'ами.
    @unmatched not {
        path /bitrix/pub /bitrix/pub/ /bitrix/pub/* /bitrix/pubweb /bitrix/pubweb/ /bitrix/pubweb/* /bitrix/api /bitrix/api/ /bitrix/api/*
        path /bitrix/sub /bitrix/sub/ /bitrix/sub/* /bitrix/subws /bitrix/subws/ /bitrix/subws/*
    }
    handle @unmatched {
        redir https://{host}{uri} permanent
    }

    log {
        output stdout
        format console
        level INFO
    }
}

# ---------- HTTPS listener — публичный сайт ----------
https://{$DOMAIN}, https://localhost, https://127.0.0.1, https://[::1] {
    encode zstd gzip

    request_body {
        max_size 256MB
    }

    # Публикация команд со стороны Битрикса (PHP) и JSON-RPC.
    # Дублируем то же правило из http://-блока: по HTTPS Битрикс стучится
    # за событиями/JSON-RPC в /bitrix/api/ и /bitrix/pub*/ (см. настройки
    # модуля pull), и публикация должна работать и снаружи по HTTPS тоже.
    @pushPub path /bitrix/pub* /bitrix/pubweb* /bitrix/api*
    handle @pushPub {
        reverse_proxy push-server:8010 {
            transport http {
                dial_timeout 30s
                response_header_timeout 60s
                read_timeout 3600s
                write_timeout 60s
            }
        }
    }

    # Подписка клиентов на push-события — основной сценарий.
    # /bitrix/sub/   — long-polling fallback (старые браузеры без WS).
    # /bitrix/subws/ — WebSocket. Браузер открывает его именно по wss://,
    # поэтому правило ОБЯЗАТЕЛЬНО должно быть и в https://-блоке, иначе
    # Caddy отправит запрос в PHP и вернёт 404.
    @pushSub path /bitrix/sub* /bitrix/subws*
    handle @pushSub {
        reverse_proxy push-server-sub:8011 {
            transport http {
                dial_timeout 30s
                response_header_timeout 60s
                read_timeout 3600s
                write_timeout 60s
            }
        }
    }

    # MailHog UI под отдельным путём
    handle /mailhog/* {
        reverse_proxy mailhog:8025
    }

    # Healthcheck самого Caddy
    handle /health {
        respond "OK" 200
    }

    # Основной root
    root * /var/www/html

    # PHP-файлы (включая /bitrix/urlrewrite.php и /index.php) — сразу в FPM
    @php path *.php
    handle @php {
        php_fastcgi php:9000
    }

    # Front controller Битрикса (аналог mod_rewrite из .htaccess):
    #   - если {path} — реальный файл → оставить как есть;
    #   - если {path}/index.php существует → подменить URI на него;
    #   - иначе → fallback в /bitrix/urlrewrite.php (Битрикс сам разберёт ЧПУ).
    # Это лечит /online/ (берёт /online/index.php), /rest/calendar.settings.get.json
    # (файла нет → urlrewrite.php → REST-роутер Битрикса), и любые разделы портала.
    handle {
        try_files {path} {path}/index.php /bitrix/urlrewrite.php

        # Если после try_files получился .php — отдать в FPM
        @isphp path *.php
        handle @isphp {
            php_fastcgi php:9000
        }

        # Иначе — статика (CSS, JS, картинки, шрифты)
        file_server
    }

    # Запрет обращения к чувствительным файлам
    @blocked path /.env* /.git* /.htaccess* /composer.* /docker-compose.* /Dockerfile*
    respond @blocked "Forbidden" 403

    log {
        output stdout
        format console
        level INFO
    }
}
