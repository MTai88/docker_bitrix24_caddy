# =============================================================
# Переменные окружения Bitrix24 Docker-стека
# =============================================================
# Скопируйте этот файл в `.env` и при необходимости измените значения.

# ---------- Имя проекта (префикс для контейнеров, сетей и volume) ----------
# Compose использует это имя как префикс:
#   контейнеры:    ${COMPOSE_PROJECT_NAME}-mysql-1, ...-php-1, ...
#   volume:        ${COMPOSE_PROJECT_NAME}_mysql_data, ...
#   сеть:          ${COMPOSE_PROJECT_NAME}_bitrix-network
#
# Это позволяет держать несколько стеков рядом с собственными данными.
# При копировании проекта (например docker_bitrix24 → docker_other_bitrix)
# обязательно задайте ДРУГОЕ значение в новом `.env`, иначе оба стека
# будут шарить одну БД, одну сеть и одни контейнеры.
#
# Правила: только [a-z0-9_-], в нижнем регистре, без пробелов.
COMPOSE_PROJECT_NAME=bitrix

# ---------- Домен ----------
# Домен, по которому будет доступен сайт.
# Для локальной разработки можно указать bitrix.local и прописать в /etc/hosts:
#   127.0.0.1 bitrix.local
DOMAIN=bitrix.local

# Режим локальной разработки (true — tls internal, самоподписанный сертификат).
# Поставьте false и направьте домен на IP хоста, чтобы получить настоящий сертификат.
LOCAL_DEV=true

# ---------- Порты ----------
HTTP_PORT=80
HTTPS_PORT=443
ADMINER_PORT=8080
MAILHOG_UI_PORT=8025
MAILHOG_SMTP_PORT=1025
MYSQL_PORT=3306
POSTGRES_PORT=5432

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root_secret
MYSQL_DATABASE=bitrix
MYSQL_USER=bitrix
MYSQL_PASSWORD=change_me_bitrix_pass

# ---------- PostgreSQL (опционально, --profile postgres) ----------
POSTGRES_USER=bitrix
POSTGRES_PASSWORD=change_me_postgres_pass
POSTGRES_DB=bitrix

# ---------- PHP ----------
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300
PHP_UPLOAD_MAX_FILESIZE=128M
PHP_POST_MAX_SIZE=128M

# ---------- UID/GID процесса PHP-FPM внутри контейнера ----------
# Должен совпадать с владельцем bind-mount ./www на хосте
# (на WSL это обычно 1000 — текущий пользователь).
# Тот же uid пробрасывается в entrypoint.sh, чтобы chown на volume
# php_runtime был корректным.
APP_UID=1000
APP_GID=1000

# ---------- Xdebug ----------
# XDEBUG_MODE: off (выкл), develop (подсветка в IDE), debug (брейкпоинты),
#              coverage, trace, profile. По умолчанию off, чтобы не тормозить.
XDEBUG_MODE=off
# Кого слушать как IDE. host.docker.internal — хост на Docker Desktop.
XDEBUG_CLIENT_HOST=host.docker.internal
# Стандартный порт Xdebug 3
XDEBUG_CLIENT_PORT=9003
# trigger — включается через cookie/GET XDEBUG_SESSION=1 (удобно для отладки одного запроса)
# yes — на каждом запросе (тормозит)
XDEBUG_START_WITH_REQUEST=trigger

# ---------- Таймзона ----------
TZ=Europe/Moscow

# ---------- Push-сервер ----------
# Должен быть >= 32 символов. Сгенерируйте свой через: openssl rand -hex 32
PUSH_SECURITY_KEY=change_me_push_security_key_32_chars_minimum
